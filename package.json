{
  "name": "peter_asn3",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "check": "tsc --noEmit",
    "preview": "vite preview",
    "old_lint": "eslint --flag unstable_native_nodejs_ts_config . --config eslint.config.ts --ext ts,cts,mts --report-unused-disable-directives & tsc --noEmit -p . && echo test",
    "lint": "oxlint & eslint --flag unstable_native_nodejs_ts_config . --config eslint.config.ts --ext ts,cts,mts --report-unused-disable-directives",
    "lint-fix": "oxlint --fix & eslint --flag unstable_native_nodejs_ts_config . --config eslint.config.ts --ext ts,cts,mts --report-unused-disable-directives --fix",
    "lint-fix-suggestions": "oxlint --fix-suggestions & eslint --flag unstable_native_nodejs_ts_config . --config eslint.config.ts --ext ts,cts,mts --report-unused-disable-directives --fix",
    "lint-fix-dangerously": "oxlint --fix-dangerously & eslint --flag unstable_native_nodejs_ts_config . --config eslint.config.ts --ext ts,cts,mts --report-unused-disable-directives --fix",
    "eslint-inspect": "npx @eslint/config-inspector@latest",
    "check-updates": "npm-check-updates --interactive --target latest",
    "check-updates-beta": "npm-check-updates --interactive --target newest",
    "check-updates-and-test": "npm-check-updates --doctor --upgrade --target latest",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prettier:write": "prettier --write . && git add --renormalize .",
    "prettier:check": "prettier --check ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vitest/ui": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-oxlint": "^1.51.0",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "npm-check-updates": "^19.6.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0-beta.16",
    "vite-plugin-oxlint": "^2.0.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "vite": "^8.0.0-beta.16"
  },
  "prettier": {
    "singleQuote": true,
    "objectWrap": "collapse",
    "printWidth": 120
  }
}
