{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "unicorn",
    "typescript",
    "oxc",
    "import",
    "jsdoc",
    "vitest",
    "promise",
    "node"
  ],
  "categories": {
    "restriction": "deny"
  },
  "rules": {
    "class-methods-use-this": "deny",
    "complexity": "deny",
    "constructor-super": "warn",
    "default-case": "deny",
    "for-direction": "warn",
    "no-alert": "deny",
    "no-async-promise-executor": "warn",
    "no-bitwise": "deny",
    "no-caller": "warn",
    "no-class-assign": "warn",
    "no-compare-neg-zero": "warn",
    "no-cond-assign": "warn",
    "no-console": "deny",
    "no-const-assign": "warn",
    "no-constant-binary-expression": "warn",
    "no-constant-condition": "warn",
    "no-control-regex": "warn",
    "no-debugger": "warn",
    "no-delete-var": "warn",
    "no-div-regex": "deny",
    "no-dupe-class-members": "warn",
    "no-dupe-else-if": "warn",
    "no-dupe-keys": "warn",
    "no-duplicate-case": "warn",
    "no-empty": "deny",
    "no-empty-character-class": "warn",
    "no-empty-function": "deny",
    "no-empty-pattern": "warn",
    "no-empty-static-block": "warn",
    "no-eq-null": "deny",
    "no-eval": "warn",
    "no-ex-assign": "warn",
    "no-extra-boolean-cast": "warn",
    "no-func-assign": "warn",
    "no-global-assign": "warn",
    "no-import-assign": "warn",
    "no-invalid-regexp": "warn",
    "no-irregular-whitespace": "warn",
    "no-iterator": "warn",
    "no-loss-of-precision": "warn",
    "no-misleading-character-class": "warn",
    "no-new-native-nonconstructor": "warn",
    "no-nonoctal-decimal-escape": "warn",
    "no-obj-calls": "warn",
    "no-param-reassign": "deny",
    "no-plusplus": "deny",
    "no-proto": "deny",
    "no-regex-spaces": "deny",
    "no-restricted-globals": "deny",
    "no-restricted-imports": "deny",
    "no-self-assign": "warn",
    "no-sequences": "deny",
    "no-setter-return": "warn",
    "no-shadow-restricted-names": "warn",
    "no-sparse-arrays": "warn",
    "no-this-before-super": "warn",
    "no-unassigned-vars": "warn",
    "no-undefined": "deny",
    "no-unsafe-finally": "warn",
    "no-unsafe-negation": "warn",
    "no-unsafe-optional-chaining": "warn",
    "no-unused-expressions": "warn",
    "no-unused-labels": "warn",
    "no-unused-private-class-members": "warn",
    "no-unused-vars": "warn",
    "no-use-before-define": "deny",
    "no-useless-backreference": "warn",
    "no-useless-catch": "warn",
    "no-useless-escape": "warn",
    "no-useless-rename": "warn",
    "no-var": "deny",
    "no-void": "deny",
    "no-with": "warn",
    "require-yield": "warn",
    "unicode-bom": "deny",
    "use-isnan": "warn",
    "valid-typeof": "warn",
    "import/default": "warn",
    "import/extensions": "deny",
    "import/namespace": "warn",
    "import/no-amd": "deny",
    "import/no-commonjs": "deny",
    "import/no-cycle": "deny",
    "import/no-default-export": "deny",
    "import/no-dynamic-require": "deny",
    "import/no-relative-parent-imports": "deny",
    "import/no-webpack-loader-syntax": "deny",
    "import/unambiguous": "deny",
    "jest/expect-expect": "warn",
    "jest/no-conditional-expect": "warn",
    "jest/no-disabled-tests": "warn",
    "jest/no-export": "warn",
    "jest/no-focused-tests": "warn",
    "jest/no-standalone-expect": "warn",
    "jest/require-to-throw-message": "warn",
    "jest/valid-describe-callback": "warn",
    "jest/valid-expect": "warn",
    "jest/valid-title": "warn",
    "jsdoc/check-access": "deny",
    "jsdoc/check-property-names": "warn",
    "jsdoc/check-tag-names": "warn",
    "jsdoc/empty-tags": "deny",
    "jsdoc/implements-on-classes": "warn",
    "jsdoc/no-defaults": "warn",
    "jsdoc/require-property": "warn",
    "jsdoc/require-property-description": "warn",
    "jsdoc/require-property-name": "warn",
    "jsdoc/require-property-type": "warn",
    "jsdoc/require-yields": "warn",
    "node/no-new-require": "deny",
    "node/no-path-concat": "deny",
    "node/no-process-env": "deny",
    "oxc/bad-array-method-on-arguments": "warn",
    "oxc/bad-bitwise-operator": "deny",
    "oxc/bad-char-at-comparison": "warn",
    "oxc/bad-comparison-sequence": "warn",
    "oxc/bad-min-max-func": "warn",
    "oxc/bad-object-literal-comparison": "warn",
    "oxc/bad-replace-all-arg": "warn",
    "oxc/const-comparisons": "warn",
    "oxc/double-comparisons": "warn",
    "oxc/erasing-op": "warn",
    "oxc/missing-throw": "warn",
    "oxc/no-async-await": "deny",
    "oxc/no-barrel-file": "deny",
    "oxc/no-const-enum": "deny",
    "oxc/no-optional-chaining": "deny",
    "oxc/no-rest-spread-properties": "deny",
    "oxc/number-arg-out-of-range": "warn",
    "oxc/only-used-in-recursion": "warn",
    "oxc/uninvoked-array-callback": "warn",
    "promise/catch-or-return": "deny",
    "promise/no-callback-in-promise": "warn",
    "promise/no-new-statics": "warn",
    "promise/spec-only": "deny",
    "promise/valid-params": "warn",
    "typescript/await-thenable": "warn",
    "typescript/ban-types": "allow",
    "typescript/explicit-function-return-type": "deny",
    "typescript/explicit-module-boundary-types": "deny",
    "typescript/no-array-delete": "warn",
    "typescript/no-base-to-string": "warn",
    "typescript/no-duplicate-enum-values": "warn",
    "typescript/no-duplicate-type-constituents": "warn",
    "typescript/no-dynamic-delete": "deny",
    "typescript/no-empty-object-type": "deny",
    "typescript/no-explicit-any": "deny",
    "typescript/no-extra-non-null-assertion": "warn",
    "typescript/no-floating-promises": "warn",
    "typescript/no-for-in-array": "warn",
    "typescript/no-implied-eval": "warn",
    "typescript/no-import-type-side-effects": "deny",
    "typescript/no-invalid-void-type": "deny",
    "typescript/no-meaningless-void-operator": "warn",
    "typescript/no-misused-new": "warn",
    "typescript/no-misused-spread": "warn",
    "typescript/no-namespace": "deny",
    "typescript/no-non-null-asserted-nullish-coalescing": "deny",
    "typescript/no-non-null-asserted-optional-chain": "warn",
    "typescript/no-non-null-assertion": "deny",
    "typescript/no-redundant-type-constituents": "warn",
    "typescript/no-require-imports": "deny",
    "typescript/no-restricted-types": "deny",
    "typescript/no-this-alias": "warn",
    "typescript/no-unnecessary-parameter-property-assignment": "warn",
    "typescript/no-unsafe-declaration-merging": "warn",
    "typescript/no-unsafe-unary-minus": "warn",
    "typescript/no-useless-empty-export": "warn",
    "typescript/no-var-requires": "deny",
    "typescript/no-wrapper-object-types": "warn",
    "typescript/non-nullable-type-assertion-style": "deny",
    "typescript/prefer-as-const": "warn",
    "typescript/prefer-literal-enum-member": "deny",
    "typescript/prefer-namespace-keyword": "warn",
    "typescript/promise-function-async": "deny",
    "typescript/require-array-sort-compare": "warn",
    "typescript/restrict-template-expressions": "warn",
    "typescript/triple-slash-reference": "warn",
    "typescript/unbound-method": "warn",
    "typescript/use-unknown-in-catch-callback-variable": "deny",
    "unicorn/no-abusive-eslint-disable": "deny",
    "unicorn/no-anonymous-default-export": "deny",
    "unicorn/no-array-for-each": "deny",
    "unicorn/no-array-reduce": "deny",
    "unicorn/no-await-in-promise-methods": "warn",
    "unicorn/no-document-cookie": "deny",
    "unicorn/no-empty-file": "warn",
    "unicorn/no-invalid-fetch-options": "warn",
    "unicorn/no-invalid-remove-event-listener": "warn",
    "unicorn/no-length-as-slice-end": "deny",
    "unicorn/no-magic-array-flat-depth": "deny",
    "unicorn/no-new-array": "warn",
    "unicorn/no-process-exit": "deny",
    "unicorn/no-single-promise-in-promise-methods": "warn",
    "unicorn/no-thenable": "warn",
    "unicorn/no-unnecessary-await": "warn",
    "unicorn/no-useless-error-capture-stack-trace": "deny",
    "unicorn/no-useless-fallback-in-spread": "warn",
    "unicorn/no-useless-length-check": "warn",
    "unicorn/no-useless-spread": "warn",
    "unicorn/prefer-modern-math-apis": "deny",
    "unicorn/prefer-module": "deny",
    "unicorn/prefer-node-protocol": "deny",
    "unicorn/prefer-number-properties": "deny",
    "unicorn/prefer-set-size": "warn",
    "unicorn/prefer-string-starts-ends-with": "warn",
    "vitest/consistent-each-for": "warn",
    "vitest/hoisted-apis-on-top": "warn",
    "vitest/no-conditional-tests": "warn",
    "vitest/require-local-test-context-for-concurrent-snapshots": "warn",
    "vitest/warn-todo": "warn"
  },
  "settings": {
    "jsx-a11y": {
      "polymorphicPropName": null,
      "components": {},
      "attributes": {}
    },
    "next": {
      "rootDir": []
    },
    "react": {
      "formComponents": [],
      "linkComponents": [],
      "version": null,
      "componentWrapperFunctions": []
    },
    "jsdoc": {
      "ignorePrivate": false,
      "ignoreInternal": false,
      "ignoreReplacesDocs": true,
      "overrideReplacesDocs": true,
      "augmentsExtendsReplacesDocs": false,
      "implementsReplacesDocs": false,
      "exemptDestructuredRootsFromChecks": false,
      "tagNamePreference": {}
    },
    "vitest": {
      "typecheck": true
    }
  },
  "env": {
    "browser": true,
    "es2022": true,
    "builtin": true
  },
  "globals": {},
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "ignorePatterns": []
}
